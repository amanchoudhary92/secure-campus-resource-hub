# Public Supabase project URL. Safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Optional public anon key. Only use this in browser clients if your code needs it.
# Keep this as a placeholder in GitHub; never paste real project secrets here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Server-only Supabase service role key.
# Never expose this in frontend code and never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Storage bucket name.
SUPABASE_STORAGE_BUCKET=resource-files

# Private admin emails. Do not publish your real admin email in public README/demo docs.
ADMIN_EMAILS=admin@example.com

# Local development URL. In Vercel, set this to your production app URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
